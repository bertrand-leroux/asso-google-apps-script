### --- 4. Page suivante (itérer pageIndex jusqu'à pagination.totalPages) ---
GET {{baseUrl}}/v5/organizations/{{orgSlug}}/forms/{{formType}}/{{formSlug}}/items
    ?withDetails=true
    &pageSize=100
    &pageIndex=2
Authorization: Bearer {{token}}

### --- 5. Lister tous les formulaires de l'asso (trouver formType/slug) ---
GET {{baseUrl}}/v5/organizations/{{orgSlug}}/forms
    ?pageSize=100
    &states=Public
    &states=Private
    &states=Draft
Authorization: Bearer {{token}}

### --- 6. Orders (commandes) ---
GET {{baseUrl}}/v5/organizations/{{orgSlug}}/forms/{{formType}}/{{formSlug}}/orders
    ?withDetails=true
    &pageSize=100
    &pageIndex=1
Authorization: Bearer {{token}}

### --- 7. Payments (transactions) ---
GET {{baseUrl}}/v5/organizations/{{orgSlug}}/forms/{{formType}}/{{formSlug}}/payments
    ?pageSize=100
    &pageIndex=1
Authorization: Bearer {{token}}

### --- 8. Stats du formulaire ---
GET {{baseUrl}}/v5/organizations/{{orgSlug}}/forms/{{formType}}/{{formSlug}}/stats
Authorization: Bearer {{token}}
